# ============================================================================
# Clarity Infrastructure — Variable Values
# ============================================================================
# IMPORTANT: This file contains sensitive values. Add to .gitignore!
#
# Copy this file to terraform.tfvars and fill in your actual values.
# Terraform automatically loads terraform.tfvars when you run apply.
# ============================================================================

project_id  = "clarity-pm-assistant-gcp"
region      = "us-central1"
environment = "production"

# Firebase
firebase_project_id = "clarity-pm-assistant-gcp"

# Secrets — replace with your real keys
gemini_api_key        = "YOUR_GEMINI_API_KEY_HERE"
stripe_secret_key     = "sk_live_YOUR_STRIPE_KEY_HERE"
stripe_webhook_secret = "whsec_YOUR_WEBHOOK_SECRET_HERE"

# Scaling
max_instances = 10
min_instances = 0
